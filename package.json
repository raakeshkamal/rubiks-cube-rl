{
  "name": "rubiks-cube-rl",
  "private": true,
  "workspaces": ["api", "frontend"],
  "scripts": {
    "dev": "bun --filter 'api' dev & bun --filter 'frontend' dev",
    "dev:api": "bun --filter 'api' dev",
